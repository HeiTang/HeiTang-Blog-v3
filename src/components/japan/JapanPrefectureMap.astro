<style>
  .japan-map {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 1.25rem;
  }

  .map-background {
    fill: transparent;
  }

  .prefecture {
    fill: url('#unvisited-pattern');
    pointer-events: none;
  }

  .prefecture[data-level='1'] { fill: var(--japan-level-1, #ffe3d6); }
  .prefecture[data-level='2'] { fill: var(--japan-level-2, #ffc1a5); }
  .prefecture[data-level='3'] { fill: var(--japan-level-3, #ff9a6f); }
  .prefecture[data-level='4'] { fill: var(--japan-level-4, #f66f41); }
  .prefecture[data-level='5'] { fill: var(--japan-level-5, #c9461f); }

  .prefecture > polygon,
  .prefecture > rect {
    fill: inherit;
    stroke: #202832;
    stroke-width: 2;
    stroke-linejoin: round;
    vector-effect: non-scaling-stroke;
  }

  text {
    fill: #fff;
    stroke: #202832;
    stroke-width: 2px;
    paint-order: stroke;
    text-anchor: middle;
    dominant-baseline: middle;
    font-family: 'Noto Sans TC', sans-serif;
    font-size: 18px;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  .small-label {
    font-size: 14px;
  }

  .vertical-label {
    writing-mode: vertical-rl;
  }
</style>
