---
/** SVG geometry adapted from ukyouz/JapanEx under the MIT License. */
import {
  japanLevelLabels,
  japanPrefectureById,
  type PrefectureId,
} from '../../data/japan';

const levelFor = (id: PrefectureId) => japanPrefectureById.get(id)?.level ?? 0;
const titleFor = (id: PrefectureId) => {
  const prefecture = japanPrefectureById.get(id);
  const level = prefecture?.level ?? 0;
  return `${prefecture?.name ?? id}：Level ${level} ${japanLevelLabels[level].label}`;
};
