---
/**
 * LanguageSwitcher — Switches between zh and en while preserving path
 */
import { getLangFromUrl, getAlternateLangUrl } from '../../i18n';

const url = Astro.url;
const currentLang = getLangFromUrl(url);
const altLang = currentLang === 'zh' ? 'en' : 'zh';
const altUrl = getAlternateLangUrl(url, altLang);

const labels = { zh: '中文', en: 'EN' };
---
<a
  href={altUrl}
  class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-sm font-medium
    glass border border-[var(--glass-border)] 
    text-[rgb(var(--color-text-secondary))] hover:text-[rgb(var(--color-primary))]
    hover:border-[rgba(var(--color-primary),0.4)] transition-all duration-200"
  title={`Switch to ${altLang === 'zh' ? '繁體中文' : 'English'}`}
>
  <span class="text-xs opacity-60">{labels[currentLang]}</span>
  <svg class="w-3.5 h-3.5 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
      d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
  </svg>
  <span class="text-xs">{labels[altLang]}</span>
</a>
