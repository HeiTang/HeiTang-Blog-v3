---
/**
 * Footer Component
 * Following SOLID principles: Single Responsibility
 */
import { siteConfig } from '../../config/site';

const currentYear = new Date().getFullYear();
---

<footer class="mt-auto relative z-20">
  <div class="container mx-auto px-6 py-4">
    <div class="w-32 h-px mx-auto mb-4" style="background: linear-gradient(to right, transparent, rgba(255,255,255,0.12), transparent);"></div>
    <p class="text-center text-xs text-white/20">
      © {currentYear} HeiTang. All Rights Reserved.
    </p>
  </div>
</footer>
