---
/**
 * InviteCodeCard — Displays a single invite code with copy functionality
 * Single Responsibility: one card, one code
 */
import type { InviteCode } from '../../types/invite';

export interface Props {
  code: InviteCode;
  lang?: 'zh' | 'en';
}

const { code, lang = 'zh' } = Astro.props;

const statusLabel: Record<InviteCode['status'], { zh: string; en: string; color: string }> = {
  active:  { zh: '有效',   en: 'Active',  color: 'text-green-400 border-green-500/30 bg-green-500/10' },
  expired: { zh: '已到期', en: 'Expired', color: 'text-red-400 border-red-500/30 bg-red-500/10' },
  limited: { zh: '名額有限', en: 'Limited', color: 'text-yellow-400 border-yellow-500/30 bg-yellow-500/10' },
};
const status = statusLabel[code.status];
---

<div class="bento-cell p-5 flex flex-col gap-3">
  <!-- Header -->
  <div class="flex items-center justify-between gap-3">
    <div>
      <h3 class="font-display font-bold text-sm text-[rgb(var(--color-text-primary))]">
        {code.service}
      </h3>
      {code.url && (
        <a href={code.url} target="_blank" rel="noopener noreferrer"
          class="text-xs text-[rgb(var(--color-primary))] hover:underline">{code.url.replace(/^https?:\/\//, '')}</a>
      )}
    </div>
    <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium border ${status.color}`}>
      {lang === 'zh' ? status.zh : status.en}
    </span>
  </div>

  <!-- Description -->
  <p class="text-xs text-[rgb(var(--color-text-secondary))] leading-relaxed">
    {lang === 'en' && code.descriptionEn ? code.descriptionEn : code.description}
  </p>

  <!-- Code copy row -->
  <div class="flex items-center gap-2 mt-auto">
    <code class="flex-1 font-mono text-sm bg-[rgba(var(--color-accent),0.1)] text-[rgb(var(--color-accent))]
      px-3 py-1.5 rounded-lg border border-[rgba(var(--color-accent),0.2)] truncate">
      {code.code}
    </code>
    <button
      class="copy-btn flex-shrink-0 px-3 py-1.5 rounded-lg text-xs font-medium
        glass border border-[var(--glass-border)]
        text-[rgb(var(--color-text-secondary))] hover:text-[rgb(var(--color-primary))]
        hover:border-[rgba(var(--color-primary),0.4)] transition-all duration-200"
      data-code={code.code}
    >
      {lang === 'zh' ? '複製' : 'Copy'}
    </button>
  </div>

  <!-- Expiry -->
  {code.expiry && (
    <p class="text-xs text-[rgb(var(--color-text-secondary))]">
      {lang === 'zh' ? '到期：' : 'Expires: '}{code.expiry}
    </p>
  )}
</div>

<script>
  document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const code = btn.dataset.code ?? '';
      await navigator.clipboard.writeText(code);
      const orig = btn.textContent;
      btn.textContent = '✓ 已複製';
      btn.classList.add('text-green-400');
      setTimeout(() => {
        btn.textContent = orig;
        btn.classList.remove('text-green-400');
      }, 1800);
    });
  });
</script>
