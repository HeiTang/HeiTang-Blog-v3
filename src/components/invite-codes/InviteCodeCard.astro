---
/**
 * InviteCodeCard — Minimal card; details open in Modal (desktop) or Bottom Sheet (mobile)
 * Single Responsibility: preview only, no inline actions
 */
import type { InviteCode } from '../../types/invite';

export interface Props {
  code: InviteCode;
}

const { code } = Astro.props;

const statusConfig = {
  active:   { label: '有效',   color: 'text-green-400 border-green-500/30 bg-green-500/10' },
  expired:  { label: '已到期', color: 'text-red-400 border-red-500/30 bg-red-500/10' },
  disabled: { label: '已停用', color: 'text-zinc-400 border-zinc-500/30 bg-zinc-500/10' },
};
const s = statusConfig[code.status];
---

<div class:list={[
  "liquid-glass-card card-interactive ic-card cursor-pointer p-5 flex flex-col gap-3 select-none",
  code.status === 'disabled' && "opacity-55",
]}
  data-status={code.status}
  data-invite={JSON.stringify(code)}
  role="button"
  tabindex="0"
  aria-label={`查看 ${code.title} 邀請碼詳情`}
>
  <!-- Title -->
  <h3 class="font-display font-bold text-sm text-[rgb(var(--color-text-primary))] leading-snug">
    {code.title}
  </h3>

  <!-- Status badge + detail tags -->
  <div class="flex flex-wrap items-center gap-1.5">
    <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium border ${s.color}`}>
      {s.label}
    </span>
    {code.tags && code.tags.length > 0 && code.tags.map(tag => (
      <span class="text-xs px-2 py-0.5 rounded-full
        bg-[rgba(var(--color-accent),0.12)] text-[rgb(var(--color-accent))]
        border border-[rgba(var(--color-accent),0.2)]">
        {tag}
      </span>
    ))}
  </div>

  <!-- Description (2 lines max) -->
  <p class="text-xs text-[rgb(var(--color-text-secondary))] leading-relaxed line-clamp-2 flex-1">
    {code.description}
  </p>

  <!-- Footer hint -->
  <div class="flex items-center justify-end pt-1.5 border-t border-[rgba(255,255,255,0.06)]">
    <span class="text-xs text-[rgb(var(--color-primary))] font-medium opacity-80 flex items-center gap-1">
      查看詳情
      <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
        <path d="M4.5 2.5L7.5 6l-3 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </span>
  </div>
</div>

