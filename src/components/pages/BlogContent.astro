---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../blog/PostCard.astro';
import { getCollection } from 'astro:content';
import { getReadingTime } from '../../utils/reading-time';
import { useTranslations, localePath } from '../../i18n';
import type { SupportedLang } from '../../config/site';

interface Props {
  lang: SupportedLang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const currentPath = localePath('/blog', lang);

const allPosts = await getCollection('blog', ({ data }) => {
  if (data.draft) return false;
  if (lang === 'zh') return data.lang === 'zh';
  return true;
});
const posts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .map(p => ({ ...p, readingTime: getReadingTime(p.body ?? '') }));

const allTags = [...new Set(posts.flatMap(p => p.data.tags))].sort();
---

<BaseLayout title={t.blog.title} currentPath={currentPath} lang={lang}>
  <div class="container mx-auto px-6 py-24">
    <!-- Page header -->
    <div class="mb-10">
      <h1 class="font-display text-4xl font-bold mb-3 text-[rgb(var(--color-text-primary))]">
        📝 {t.blog.title}
      </h1>
      <p class="text-[rgb(var(--color-text-secondary))]">
        {posts.length} {t.blog.articleCount}
      </p>
    </div>

    <!-- Search (Pagefind UI) -->
    <div class="mb-8" id="search-container">
      <div id="search"></div>
    </div>

    <!-- Tag filter -->
    {allTags.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-8">
        <button class="tag-badge tag-filter active" data-tag="all">{t.blog.allTags}</button>
        {allTags.map(tag => (
          <button class="tag-badge tag-filter" data-tag={tag}>{tag}</button>
        ))}
      </div>
    )}

    <!-- Posts grid -->
    {posts.length === 0 ? (
      <div class="glass p-12 rounded-2xl text-center">
        <p class="text-[rgb(var(--color-text-secondary))] text-lg">✍️ {lang === 'zh' ? '文章即將到來…' : 'Articles coming soon…'}</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4" id="posts-grid">
        {posts.map(post => (
          <div class="post-item card-interactive rounded-3xl border border-white/[0.08] overflow-hidden" style="background: var(--bento-card-bg); backdrop-filter: blur(var(--glass-blur)); -webkit-backdrop-filter: blur(var(--glass-blur));" data-tags={post.data.tags.join(',')}>
            <PostCard
              slug={post.id}
              title={lang === 'en' ? (post.data.titleEn ?? post.data.title) : post.data.title}
              description={lang === 'en' ? (post.data.descriptionEn ?? post.data.description) : post.data.description}
              pubDate={post.data.pubDate}
              tags={post.data.tags}
              readingTime={post.readingTime}
              lang={lang}
            />
          </div>
        ))}
      </div>
    )}
  </div>

  <!-- Pagefind: dynamically loaded so Astro doesn't try to inline missing files at build time -->
  <script is:inline>
    (function() {
      var link = document.createElement('link');
      link.rel = 'stylesheet';
      link.href = '/pagefind/pagefind-ui.css';
      document.head.appendChild(link);

      var script = document.createElement('script');
      script.src = '/pagefind/pagefind-ui.js';
      script.onload = function() {
        if (window.PagefindUI) {
          new window.PagefindUI({ element: '#search', showSubResults: true });
        }
      };
      document.head.appendChild(script);
    })();
  </script>
</BaseLayout>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.tag-filter');
  const postItems = document.querySelectorAll<HTMLElement>('.post-item');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const tag = btn.dataset.tag ?? 'all';
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      postItems.forEach(item => {
        const tags = item.dataset.tags ?? '';
        item.style.display = tag === 'all' || tags.split(',').includes(tag) ? '' : 'none';
      });
    });
  });
</script>

<style>
  .tag-filter.active {
    background: rgba(var(--color-primary), 0.25);
    border-color: rgba(var(--color-primary), 0.5);
    color: rgb(var(--color-primary));
  }

  #search {
    --pagefind-ui-scale: 0.9;
    --pagefind-ui-primary: rgb(var(--color-primary));
    --pagefind-ui-text: rgb(var(--color-text-primary));
    --pagefind-ui-background: rgba(255,255,255,0.04);
    --pagefind-ui-border: rgba(255,255,255,0.1);
    --pagefind-ui-tag: rgba(var(--color-primary), 0.15);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 14px;
    --pagefind-ui-font: inherit;
  }

  #search .pagefind-ui__search-input {
    background: rgba(255,255,255,0.05) !important;
    border: 1px solid rgba(255,255,255,0.1) !important;
    border-radius: 14px !important;
    color: rgb(var(--color-text-primary)) !important;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    padding: 0.75rem 1rem 0.75rem 2.75rem !important;
  }
  #search .pagefind-ui__search-input:focus {
    border-color: rgba(var(--color-primary), 0.5) !important;
    box-shadow: 0 0 0 3px rgba(var(--color-primary), 0.12) !important;
    outline: none !important;
  }
  #search .pagefind-ui__search-input::placeholder {
    color: rgb(var(--color-text-secondary)) !important;
  }
  #search .pagefind-ui__search-clear {
    color: rgb(var(--color-text-secondary)) !important;
  }
  #search .pagefind-ui__results-area {
    margin-top: 1rem;
  }
  #search .pagefind-ui__result {
    background: rgba(255,255,255,0.04) !important;
    border: 1px solid rgba(255,255,255,0.08) !important;
    border-radius: 14px !important;
    padding: 1.25rem 1.5rem !important;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    transition: border-color 0.2s ease, transform 0.2s ease;
  }
  #search .pagefind-ui__result:hover {
    border-color: rgba(var(--color-primary), 0.35) !important;
    transform: translateY(-1px);
  }
  #search .pagefind-ui__result + .pagefind-ui__result {
    margin-top: 0.75rem;
    border-top: none !important;
  }
  #search .pagefind-ui__result-title {
    color: rgb(var(--color-text-primary)) !important;
    font-weight: 600;
  }
  #search .pagefind-ui__result-link {
    color: rgb(var(--color-primary)) !important;
  }
  #search .pagefind-ui__result-link:hover {
    text-decoration: underline;
  }
  #search .pagefind-ui__result-excerpt {
    color: rgb(var(--color-text-secondary)) !important;
    font-size: 0.875rem;
    margin-top: 0.375rem;
  }
  #search .pagefind-ui__result-excerpt mark {
    background: rgba(var(--color-primary), 0.25) !important;
    color: rgb(var(--color-primary)) !important;
    border-radius: 3px;
    padding: 0 2px;
  }
  #search .pagefind-ui__message {
    color: rgb(var(--color-text-secondary)) !important;
    font-size: 0.85rem;
    margin-bottom: 0.75rem;
  }
  #search .pagefind-ui__button {
    background: rgba(var(--color-primary), 0.1) !important;
    border: 1px solid rgba(var(--color-primary), 0.3) !important;
    border-radius: 10px !important;
    color: rgb(var(--color-primary)) !important;
    padding: 0.5rem 1.25rem !important;
    cursor: pointer;
    transition: background 0.2s ease;
  }
  #search .pagefind-ui__button:hover {
    background: rgba(var(--color-primary), 0.2) !important;
  }
</style>
