  .card-style-1 { transform: rotate(-0.8deg); }
  .card-style-2 { transform: rotate(0.65deg); }
  .card-style-3 { transform: rotate(-0.45deg); }
  .experience-icon {
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 0.75rem;
    display: grid;
    place-items: center;
    color: rgb(var(--color-primary));
    background: rgba(var(--color-primary), 0.16);
  }
  .experience-arrow {
    margin-top: auto;
    color: rgb(var(--color-primary));
    font-size: 0.82rem;
    font-weight: 600;
  }

  .section-head-posts {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 0.9rem;
  }
  .posts-all-link {
    color: rgb(var(--color-primary));
    font-size: 0.83rem;
    transition: opacity 0.2s ease;
  }
  .posts-all-link:hover { opacity: 0.8; }

  .recent-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.85rem;
