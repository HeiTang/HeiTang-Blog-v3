    background: rgba(255, 255, 255, 0.03);
    padding: 1rem;
    min-height: 210px;
    display: flex;
    flex-direction: column;
    transition: transform 0.22s ease, border-color 0.22s ease;
  }
  .recent-post:hover {
    transform: translateY(-4px);
    border-color: rgba(var(--color-primary), 0.36);
  }
  .recent-date {
    color: rgb(var(--color-text-secondary));
    font-size: 0.72rem;
    margin-bottom: 0.55rem;
  }
  .recent-title {
    color: rgb(var(--color-text-primary));
    font-size: 1.05rem;
    line-height: 1.4;
    font-weight: 600;
    margin-bottom: 0.55rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .recent-desc {
    color: rgb(var(--color-text-secondary));
    font-size: 0.9rem;
    line-height: 1.6;
    margin-bottom: auto;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .recent-meta {
    margin-top: 0.8rem;
    color: rgb(var(--color-primary));
    font-size: 0.75rem;
    font-weight: 600;
  }

  .empty-state {
    border-radius: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    padding: 1rem;
    color: rgb(var(--color-text-secondary));
    font-size: 0.9rem;
  }

  [data-reveal] {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.45s ease, transform 0.45s ease;
  }
  [data-reveal].is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .magnetic {
    will-change: transform;
  }

  .tw-cursor {
    display: inline-block;
    color: rgb(var(--color-primary));
    animation: tw-blink 0.8s step-end infinite;
    font-weight: 300;
    margin-left: 1px;
  }
  @keyframes tw-blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
  @keyframes orbit-spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  @keyframes marquee-slide {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
  @keyframes interest-float {
    0%, 100% { transform: translate(-50%, -50%) translate(0, 0); }
    50% { transform: translate(-50%, -50%) translate(6px, -10px); }
  }
  @keyframes interest-pulse {
    0%, 100% {
      opacity: 0.72;
      box-shadow:
        inset 0 0 0 1px rgba(255, 255, 255, 0.08),
        0 0 14px rgba(var(--color-primary), 0.16);
    }
    50% {
      opacity: 1;
      box-shadow:
        inset 0 0 0 1px rgba(255, 255, 255, 0.1),
        0 0 20px rgba(var(--color-primary), 0.28);
    }
  }
  @keyframes scanline {
    from { transform: translateY(-100%); }
    to { transform: translateY(160%); }
  }
  @keyframes glitch-shift-a {
    0%, 86%, 100% { clip-path: inset(0 0 0 0); transform: translate(1px, -1px); opacity: 0.16; }
    88% { clip-path: inset(20% 0 56% 0); transform: translate(3px, -2px); opacity: 0.32; }
    90% { clip-path: inset(72% 0 6% 0); transform: translate(-2px, 2px); opacity: 0.34; }
  }
  @keyframes glitch-shift-b {
    0%, 85%, 100% { clip-path: inset(0 0 0 0); transform: translate(-1px, 1px); opacity: 0.14; }
    87% { clip-path: inset(10% 0 70% 0); transform: translate(-3px, 2px); opacity: 0.28; }
    91% { clip-path: inset(64% 0 14% 0); transform: translate(2px, -2px); opacity: 0.34; }
  }

  @media (max-width: 1100px) {
    .portal-grid {
      grid-template-columns: 1fr;
    }
    .portal-visual {
      min-height: 300px;
      margin-top: 0.4rem;
      padding-bottom: 3rem;
    }
    .portal-contact-slot {
      bottom: 0.3rem;
    }
    .lab-grid {
      grid-template-columns: 1fr;
    }
    .experience-grid,
    .recent-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 760px) {
    .scroll-indicator {
      display: none;
    }
    .portal-title-wrap {
      margin-bottom: 0.9rem;
    }
    .experience-grid,
    .recent-grid {
      grid-template-columns: 1fr;
    }
    .section-head-posts {
      align-items: flex-start;
      flex-direction: column;
    }
    .contact-row {
      gap: 1.1rem;
    }
    .portal-handle {
      left: calc(100% + 0.48rem);
      bottom: -0.1rem;
    }
    .heitang-handle-tech {
      font-size: 1.5rem;
      letter-spacing: 0.13em;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .glitch-title::before,
    .glitch-title::after {
      display: none;
    }
  }
</style>

<script>
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const root = document.querySelector<HTMLElement>('.immersive-home');
  const revealItems = document.querySelectorAll<HTMLElement>('[data-reveal]');
  const parallaxNodes = document.querySelectorAll<HTMLElement>('.parallax-node');
  const magneticNodes = document.querySelectorAll<HTMLElement>('.magnetic');
  const progressBar = document.querySelector<HTMLElement>('.scroll-indicator-bar');
  const terminal = document.querySelector<HTMLElement>('.lab-terminal');

  function updateScrollProgress() {
    if (!progressBar) return;
    const scrollTop = window.scrollY;
    const docHeight = document.documentElement.scrollHeight - window.innerHeight;
    const progress = docHeight > 0 ? Math.min(100, Math.max(0, (scrollTop / docHeight) * 100)) : 0;
    progressBar.style.height = `${progress}%`;
  }

  updateScrollProgress();
  window.addEventListener('scroll', updateScrollProgress, { passive: true });

  function showItem(el: HTMLElement) {
    el.classList.add('is-visible');
  }

  if (reduceMotion) {
    revealItems.forEach(showItem);
  } else {
    const io = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return;
        showItem(entry.target as HTMLElement);
        io.unobserve(entry.target);
      });
    }, { threshold: 0.18 });
    revealItems.forEach(el => io.observe(el));
  }

  if (!reduceMotion && root) {
    window.addEventListener('pointermove', (event) => {
      const rect = root.getBoundingClientRect();
      const x = ((event.clientX - rect.left) / rect.width) * 100;
      const y = ((event.clientY - rect.top) / rect.height) * 100;
      root.style.setProperty('--mx', `${Math.max(0, Math.min(100, x))}%`);
      root.style.setProperty('--my', `${Math.max(0, Math.min(100, y))}%`);

      const dx = event.clientX - (rect.left + rect.width / 2);
      const dy = event.clientY - (rect.top + rect.height / 2);

      parallaxNodes.forEach(node => {
        const depth = Number(node.dataset.depth ?? '10');
        const tx = (dx / rect.width) * depth;
        const ty = (dy / rect.height) * depth;
        node.style.transform = `translate3d(${tx}px, ${ty}px, 0)`;
      });
    });

    magneticNodes.forEach(node => {
      node.addEventListener('mousemove', (event) => {
        const rect = node.getBoundingClientRect();
        const mx = event.clientX - (rect.left + rect.width / 2);
        const my = event.clientY - (rect.top + rect.height / 2);
        node.style.transform = `translate(${mx * 0.06}px, ${my * 0.06}px)`;
      });
      node.addEventListener('mouseleave', () => {
        node.style.transform = '';
      });
    });
  }

  if (!reduceMotion && terminal) {
    const raw = terminal.dataset.lines;
    const lineNodes = Array.from(terminal.querySelectorAll<HTMLElement>('.terminal-line'));

    if (raw && lineNodes.length > 0) {
      const lines = JSON.parse(raw) as string[];
      let pointer = 0;
      setInterval(() => {
        lineNodes.forEach((node, idx) => {
          const lineIndex = (pointer + idx) % lines.length;
          node.textContent = lines[lineIndex];
        });
        pointer = (pointer + 1) % lines.length;
      }, 2200);
    }
  }

  class TxtRotate {
    private el: HTMLElement;
    private toRotate: string[];
    private period: number;
    private loopNum = 0;
    private txt = '';
    private isDeleting = false;

    constructor(el: HTMLElement, toRotate: string[], period: number) {
      this.el = el;
      this.toRotate = toRotate;
      this.period = period;
      setTimeout(() => this.tick(), 500);
    }

    tick() {
      const i = this.loopNum % this.toRotate.length;
      const fullTxt = this.toRotate[i];

      this.txt = this.isDeleting
        ? fullTxt.substring(0, this.txt.length - 1)
        : fullTxt.substring(0, this.txt.length + 1);

      this.el.querySelector<HTMLElement>('.wrap')!.textContent = this.txt;

      let delta = 100 - Math.round(Math.random() * 35);
      if (this.isDeleting) delta /= 2.2;

      if (!this.isDeleting && this.txt === fullTxt) {
        delta = this.period;
        this.isDeleting = true;
      } else if (this.isDeleting && this.txt === '') {
        this.isDeleting = false;
        this.loopNum++;
        delta = 450;
      }

      setTimeout(() => this.tick(), delta);
    }
  }

  document.querySelectorAll<HTMLElement>('.txt-rotate').forEach(el => {
    const raw = el.getAttribute('data-rotate');
    if (!raw) return;

    const rotateTexts = JSON.parse(raw) as string[];
    const period = parseInt(el.getAttribute('data-period') || '2000', 10);

    if (reduceMotion) {
      el.querySelector<HTMLElement>('.wrap')!.textContent = rotateTexts[0] ?? '';
      const cursor = el.parentElement?.querySelector<HTMLElement>('.tw-cursor');
      if (cursor) cursor.style.display = 'none';
      return;
    }

    new TxtRotate(el, rotateTexts, period);
  });
</script>
