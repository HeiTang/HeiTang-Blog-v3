---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import InviteCodeCard from '../../../components/invite-codes/InviteCodeCard.astro';
import { fetchInviteCodes } from '../../../services/inviteCodes';
import { formatDate } from '../../../utils/date';

const lang = 'en';
const { codes, updatedAt } = await fetchInviteCodes();
---

<BaseLayout title="Invite Codes" lang={lang} currentPath="/en/invite-codes">
  <div class="container mx-auto px-6 py-24">
    <div class="mb-10">
      <h1 class="font-display text-4xl font-bold mb-3 text-[rgb(var(--color-text-primary))]">
        🎫 Invite Codes
      </h1>
      <p class="text-[rgb(var(--color-text-secondary))] mb-2">
        Invite codes for services I use and recommend
      </p>
      <p class="text-xs text-[rgb(var(--color-text-secondary))]">
        Last updated: {formatDate(updatedAt, lang)}
      </p>
    </div>

    {codes.length === 0 ? (
      <div class="glass p-12 rounded-2xl text-center">
        <p class="text-[rgb(var(--color-text-secondary))] text-lg">No invite codes available</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {codes.map(code => <InviteCodeCard code={code} lang={lang} />)}
      </div>
    )}
  </div>
</BaseLayout>
