---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../config/site';
---

<BaseLayout title={siteConfig.title} currentPath="/" lang="zh">
  <div class="min-h-[calc(100vh-4rem)] flex items-center justify-center px-6">
    <div class="text-center max-w-sm w-full">

      <!-- Avatar -->
      <div data-animate class="mx-auto w-28 h-28 rounded-full mb-6 overflow-hidden
        ring-2 ring-[rgba(var(--color-primary),0.4)] ring-offset-4 ring-offset-transparent"
        style="box-shadow: 0 0 40px rgba(var(--color-primary), 0.15);">
        <img src="/images/profile.jpeg" alt="黑糖不是炭" class="w-full h-full object-cover" />
      </div>

      <!-- Typewriter sentence -->
      <p data-animate class="text-[rgb(var(--color-text-secondary))] mb-3 leading-relaxed min-h-[1.6em]">
        嗨！我是一隻
        <span class="txt-rotate font-medium text-[rgb(var(--color-primary))]"
          data-period="2000"
          data-rotate='["橘線迷路的橘貓 /ᐠ-˕-マⳊ", "不胖只是蓬鬆的橘貓 ₍˄•༝•˄₎◞✩︎", "記得放飯的鏟屎官 ₍^..^₎ 𐒡"]'
        ><span class="wrap"></span></span><span class="tw-cursor">▍</span>
      </p>

      <!-- Name -->
      <h1 data-animate class="pixel-title font-bold text-3xl text-[rgb(var(--color-text-primary))] mb-8
        [text-shadow:0_0_30px_rgba(var(--color-primary),0.3)]">
        黑糖不是炭
      </h1>

      <!-- Social icons -->
      <div data-animate class="flex justify-center items-center gap-6">

        <a href={siteConfig.social.github} target="_blank" rel="noopener noreferrer"
          aria-label="GitHub"
          class="social-icon group">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
          </svg>
          <span class="social-label">GitHub</span>
        </a>

        <a href={`mailto:${siteConfig.social.email}`}
          aria-label="Email"
          class="social-icon group">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          <span class="social-label">Email</span>
        </a>

        <a href="/rss.xml" target="_blank" rel="noopener noreferrer"
          aria-label="RSS"
          class="social-icon group">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M6.18 15.64a2.18 2.18 0 012.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 012.18-2.18M4 4.44A15.56 15.56 0 0119.56 20h-2.83A12.73 12.73 0 004 7.27V4.44m0 5.66a9.9 9.9 0 019.9 9.9h-2.83A7.07 7.07 0 004 12.93V10.1z"/>
          </svg>
          <span class="social-label">RSS</span>
        </a>

      </div>

    </div>
  </div>
</BaseLayout>

<style>
  .pixel-title {
    font-family: 'DotGothic16', sans-serif;
  }

  /* Entrance animation */
  [data-animate] {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  [data-animate].is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Social icon circles */
  .social-icon {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    width: 3rem;
    height: 3rem;
    border-radius: 9999px;
    border: 2px solid rgba(var(--color-primary), 0.45);
    color: rgba(var(--color-primary), 0.75);
    transition: transform 0.3s ease, background 0.3s ease, color 0.3s ease, box-shadow 0.3s ease;
  }
  .social-icon:hover {
    transform: scale(1.25) translateY(-5px);
    background: rgb(var(--color-primary));
    color: #1a1a1a;
    box-shadow: 0 0 24px rgb(var(--color-primary));
  }
  .social-label {
    position: absolute;
    bottom: -1.8rem;
    left: 50%;
    transform: translateX(-50%) scale(0);
    font-size: 0.7rem;
    color: rgba(255,255,255,0.7);
    white-space: nowrap;
    transition: transform 0.25s ease;
    pointer-events: none;
  }
  .social-icon:hover .social-label {
    transform: translateX(-50%) scale(1);
  }

  /* Typewriter cursor */
  .tw-cursor {
    display: inline-block;
    color: rgb(var(--color-primary));
    animation: tw-blink 0.8s step-end infinite;
    font-weight: 300;
    margin-left: 1px;
  }
  @keyframes tw-blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }
</style>

<script>
  // Staggered entrance animations
  document.querySelectorAll<HTMLElement>('[data-animate]').forEach((el, i) => {
    setTimeout(() => el.classList.add('is-visible'), i * 160 + 80);
  });

  // Typewriter
  class TxtRotate {
    private el: HTMLElement;
    private toRotate: string[];
    private period: number;
    private loopNum = 0;
    private txt = '';
    private isDeleting = false;

    constructor(el: HTMLElement, toRotate: string[], period: number) {
      this.el = el;
      this.toRotate = toRotate;
      this.period = period;
      setTimeout(() => this.tick(), 600);
    }

    tick() {
      const i = this.loopNum % this.toRotate.length;
      const fullTxt = this.toRotate[i];

      this.txt = this.isDeleting
        ? fullTxt.substring(0, this.txt.length - 1)
        : fullTxt.substring(0, this.txt.length + 1);

      this.el.querySelector<HTMLElement>('.wrap')!.textContent = this.txt;

      let delta = 100 - Math.round(Math.random() * 40);
      if (this.isDeleting) delta /= 2.5;

      if (!this.isDeleting && this.txt === fullTxt) {
        delta = this.period;
        this.isDeleting = true;
      } else if (this.isDeleting && this.txt === '') {
        this.isDeleting = false;
        this.loopNum++;
        delta = 500;
      }

      setTimeout(() => this.tick(), delta);
    }
  }

  document.querySelectorAll<HTMLElement>('.txt-rotate').forEach(el => {
    const raw = el.getAttribute('data-rotate');
    const period = parseInt(el.getAttribute('data-period') || '2000', 10);
    if (raw) new TxtRotate(el, JSON.parse(raw), period);
  });
</script>

