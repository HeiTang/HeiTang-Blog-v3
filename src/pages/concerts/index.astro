---
import ConcertCard from '../../components/concerts/ConcertCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { fetchConcerts, type Concert } from '../../services/concerts';

const title = '演唱會足跡：我的現場音樂紀錄';
const description = '記錄已購票的演唱會與現場音樂活動，包含日期與場地。';
const concerts = await fetchConcerts();
const today = new Date(Date.now() + 8 * 60 * 60 * 1000).toISOString().slice(0, 10);
const dateKey = (concert: Concert) => concert.startDate.slice(0, 10);
const orderedConcerts = [...concerts].sort((a, b) => b.startDate.localeCompare(a.startDate));
const posterIndexById = new Map(orderedConcerts.map((concert, index) => [concert.id, index]));
const upcomingCount = concerts.filter(concert => dateKey(concert) >= today).length;
const venueCount = new Set(concerts.map(concert => concert.venue)).size;
const concertsByYear = orderedConcerts.reduce((groups, concert) => {
  const year = dateKey(concert).slice(0, 4);
  const group = groups.get(year) ?? [];
  group.push(concert);
  groups.set(year, group);
  return groups;
}, new Map<string, Concert[]>());
const yearGroups = [...concertsByYear].map(([year, items]) => ({ year, items }));

function formatDate(value: string): string {
  const [year, month, day] = value.slice(0, 10).split('-');
  return `${year}.${month}.${day}`;
}

function formatDateRange(concert: Concert): string {
  const start = formatDate(concert.startDate);
  if (!concert.endDate || concert.endDate.slice(0, 10) === concert.startDate.slice(0, 10)) return start;
  return `${start} — ${formatDate(concert.endDate)}`;
}

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: title,
    description,
    url: 'https://purr.tw/concerts/',
    mainEntity: {
      '@type': 'ItemList',
      numberOfItems: orderedConcerts.length,
      itemListElement: orderedConcerts.map((concert, index) => ({
        '@type': 'ListItem',
        position: index + 1,
        name: `${concert.name}｜${formatDateRange(concert)}｜${concert.venue}`,
      })),
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: '首頁', item: 'https://purr.tw/' },
      { '@type': 'ListItem', position: 2, name: '演唱會足跡', item: 'https://purr.tw/concerts/' },
    ],
  },
];
---

<BaseLayout
  title={title}
  description={description}
  currentPath="/concerts"
  image="/images/og/concerts.png"
  hasLanguageAlternate={false}
  structuredData={structuredData}
>
  <article class="page-shell" data-pagefind-body>
    <nav class="breadcrumb" aria-label="麵包屑">
      <a href="/">首頁</a>
      <span aria-hidden="true">/</span>
      <span aria-current="page">演唱會足跡</span>
    </nav>

    <header class="page-header">
      <p class="eyebrow">LIVE MUSIC ARCHIVE</p>
      <h1 class="page-title">演唱會<span>足跡</span></h1>

      <dl class="archive-stats" aria-label="演唱會統計">
        {[
          { label: '演出場次', value: concerts.length },
          { label: '收錄年份', value: yearGroups.length },
          { label: '演出場地', value: venueCount },
          { label: '即將演出', value: upcomingCount, accent: upcomingCount > 0 },
        ].map(({ label, value, accent }) => (
          <div class:list={[{ 'is-accent': accent }]}>
            <dt>{label}</dt>
            <dd>{value < 10 && <span class="stat-pad" aria-hidden="true">0</span>}{value}</dd>
          </div>
        ))}
      </dl>
    </header>

    {concerts.length === 0 ? (
      <section class="empty-state" aria-labelledby="empty-heading">
        <p class="empty-label">NO SIGNAL</p>
        <h2 id="empty-heading">目前沒有演出紀錄</h2>
        <p>已購票的演出會顯示在這裡。</p>
      </section>
    ) : (
      <section class="archive" aria-label="演唱會年份時間軸">
        {yearGroups.map(({ year, items }) => (
          <section class="year-section" aria-labelledby={`year-${year}`}>
            <header class="year-marker">
              <h2 id={`year-${year}`}>{year}</h2>
              <p>{String(items.length).padStart(2, '0')} SHOWS</p>
            </header>

            <ol class="timeline-list">
              {items.map(concert => (
                <ConcertCard
                  concert={concert}
                  future={dateKey(concert) >= today}
                  index={posterIndexById.get(concert.id) ?? 0}
                />
              ))}
            </ol>
          </section>
        ))}
      </section>
    )}
  </article>
</BaseLayout>

<style>
  .page-shell {
    width: min(1180px, calc(100% - 2rem));
    margin: 0 auto;
    padding: 7rem 0 6rem;
  }

  .breadcrumb {
    display: flex;
    gap: 0.55rem;
    align-items: center;
    margin-bottom: clamp(3rem, 7vw, 6rem);
    color: rgb(var(--color-text-secondary));
    font-size: 0.875rem;
  }

  .breadcrumb a {
    color: rgb(var(--color-text-accent));
    text-underline-offset: 0.2em;
  }

  h1,
  h2,
  p,
  dl,
  dd {
    margin-top: 0;
  }

  .eyebrow {
    margin-bottom: 0.75rem;
    color: rgb(var(--color-text-accent));
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.14em;
  }

  .page-header {
    padding-bottom: clamp(2.5rem, 5vw, 4.5rem);
  }

  .page-title {
    display: block;
    margin-bottom: clamp(2rem, 4vw, 3.5rem);
    font-size: clamp(3.3rem, 9.5vw, 7.5rem);
    font-weight: 700;
    letter-spacing: -0.055em;
    line-height: 1;
    white-space: nowrap;
  }

  .page-title span {
    color: rgb(var(--color-text-accent));
  }

  .archive-stats {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    margin-bottom: 0;
    border-block: 1px solid rgb(var(--color-text-primary) / 0.15);
  }

  .archive-stats div {
    display: flex;
    flex-direction: column;
    padding: 1.15rem 0 1.25rem;
  }

  .archive-stats div + div {
    padding-left: clamp(1rem, 3vw, 2rem);
    border-left: 1px solid rgb(var(--color-text-primary) / 0.1);
  }

  .archive-stats dd {
    order: -1;
    color: rgb(var(--color-text-primary));
    font-family: 'JetBrains Mono', monospace;
    font-size: clamp(1.6rem, 3.2vw, 2.5rem);
    font-variant-numeric: tabular-nums;
    line-height: 1;
  }

  .archive-stats dt {
    margin-top: 0.6rem;
    color: rgb(var(--color-text-secondary));
    font-size: 0.72rem;
    letter-spacing: 0.08em;
  }

  .archive-stats dt::before {
    margin-right: 0.45em;
    color: rgb(var(--color-text-accent));
    content: '/';
    font-family: 'JetBrains Mono', monospace;
  }

  .archive-stats .stat-pad {
    color: rgb(var(--color-text-primary) / 0.25);
  }

  .archive-stats .is-accent dd {
    color: rgb(var(--color-text-accent));
    text-shadow: 0 0 18px rgb(var(--color-text-accent) / 0.4);
  }

  .year-section {
    display: grid;
    grid-template-columns: minmax(170px, 0.33fr) minmax(0, 1fr);
    gap: clamp(2rem, 5vw, 5rem);
    padding-top: clamp(2.75rem, 5vw, 4.5rem);
  }

  .year-marker {
    position: sticky;
    top: 7rem;
    align-self: start;
  }

  .year-marker h2 {
    margin-bottom: 0.5rem;
    color: rgb(var(--color-text-primary));
    font-family: 'JetBrains Mono', monospace;
    font-size: clamp(3.6rem, 8vw, 7.5rem);
    font-variant-numeric: tabular-nums;
    font-weight: 400;
    letter-spacing: -0.08em;
    line-height: 0.9;
  }

  .year-marker p {
    margin-bottom: 0;
    color: rgb(var(--color-text-accent));
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.14em;
  }

  .timeline-list {
    position: relative;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(2rem, 4vw, 3.75rem) clamp(1rem, 2.5vw, 2rem);
    margin: 0;
    padding: 0 0 0 2.5rem;
    list-style: none;
  }

  .timeline-list::before {
    position: absolute;
    z-index: 0;
    top: 0;
    bottom: 0;
    left: 0.5rem;
    width: 1px;
    content: '';
    transform-origin: top;
    background: rgb(var(--color-text-accent));
    box-shadow: 0 0 14px rgb(var(--color-text-accent) / 0.55);
  }

  :global(.concert-card) {
    position: relative;
    z-index: 1;
    display: flex;
    min-width: 0;
    flex-direction: column;
  }

  :global(.timeline-node) {
    position: absolute;
    top: 1.35rem;
    left: -2.32rem;
    display: none;
    width: 0.68rem;
    aspect-ratio: 1;
    border: 2px solid rgb(var(--color-bg-dark));
    border-radius: 50%;
    background: rgb(var(--color-text-secondary));
    box-shadow: 0 0 0 1px rgb(var(--color-text-primary) / 0.24);
  }

  :global(.concert-card.is-future .timeline-node) {
    background: rgb(var(--color-text-accent));
    box-shadow:
      0 0 0 1px rgb(var(--color-text-accent) / 0.55),
      0 0 18px rgb(var(--color-text-accent) / 0.72);
  }

  :global(.concert-card:nth-child(3n + 1) .timeline-node) {
    display: block;
  }

  :global(.concert-date) {
    order: 2;
    margin-top: 0.9rem;
    color: rgb(var(--color-text-secondary));
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.78rem;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.04em;
    line-height: 1.4;
  }

  :global(.concert-card.is-future .concert-date) {
    color: rgb(var(--color-text-accent));
  }

  :global(.concert-body) {
    order: 3;
  }

  :global(.concert-status) {
    position: absolute;
    z-index: 2;
    top: 0.65rem;
    left: 0.65rem;
    margin: 0;
    padding: 0.28rem 0.6rem;
    border: 1px solid rgb(var(--color-text-accent) / 0.55);
    border-radius: 999px;
    background: rgb(var(--color-bg-dark) / 0.82);
    color: rgb(var(--color-text-accent));
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    backdrop-filter: blur(4px);
  }

  :global(.concert-body h3) {
    margin: 0.4rem 0 0.65rem;
    font-size: clamp(1rem, 1.8vw, 1.3rem);
    letter-spacing: -0.025em;
    line-height: 1.3;
  }

  :global(.concert-meta) {
    display: grid;
    gap: 0.16rem;
    margin: 0;
    color: rgb(var(--color-text-secondary));
    font-size: 0.78rem;
    line-height: 1.55;
  }

  :global(.concert-link) {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    margin-top: 0.75rem;
    color: rgb(var(--color-text-accent));
    font-size: 0.85rem;
    font-weight: 600;
    text-underline-offset: 0.25em;
  }

  /* stretched link：整張卡都可點 */
  :global(.concert-link::after) {
    position: absolute;
    inset: 0;
    content: '';
  }

  :global(.concert-card:hover .concert-link) {
    text-decoration: underline;
  }

  :global(.concert-visual) {
    position: relative;
    order: 1;
    overflow: hidden;
    width: 100%;
    aspect-ratio: 3 / 4;
    margin: 0;
    border: 1px solid rgb(var(--color-text-primary) / 0.12);
    border-radius: 0.35rem;
    background: rgb(var(--color-bg-medium));
    box-shadow: 0 1.2rem 2.4rem rgba(0, 0, 0, 0.24);
    transition: border-color 220ms ease-out, box-shadow 220ms ease-out, transform 220ms ease-out;
  }

  :global(.concert-visual img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 280ms ease-out;
  }

  :global(.concert-card.is-future .concert-visual) {
    border-color: rgb(var(--color-text-accent) / 0.45);
  }

  :global(.concert-card:hover .concert-visual),
  :global(.concert-card:focus-within .concert-visual) {
    border-color: rgb(var(--color-text-accent) / 0.58);
    box-shadow:
      0 1.5rem 3rem rgba(0, 0, 0, 0.34),
      0 0 1.6rem rgb(var(--color-text-accent) / 0.16);
    transform: translateY(-0.35rem) rotate(-0.45deg);
  }

  :global(.concert-card:hover .concert-visual img),
  :global(.concert-card:focus-within .concert-visual img) {
    transform: scale(1.04);
  }

  :global(.concert-poster-fallback) {
    position: relative;
    isolation: isolate;
    display: flex;
    height: 100%;
    flex-direction: column;
    justify-content: space-between;
    overflow: hidden;
    padding: clamp(0.85rem, 1.8vw, 1.25rem);
    background:
      radial-gradient(circle at 76% 22%, rgb(var(--color-text-accent) / 0.78), transparent 34%),
      linear-gradient(145deg, rgb(var(--color-bg-light)), rgb(var(--color-bg-dark)) 72%);
  }

  :global(.concert-poster-fallback::before) {
    position: absolute;
    z-index: -1;
    inset: -20%;
    background: repeating-linear-gradient(
      115deg,
      transparent 0 0.65rem,
      rgb(var(--color-text-primary) / 0.07) 0.65rem 0.72rem
    );
    content: '';
    transform: rotate(-8deg);
  }

  :global(.concert-poster-fallback::after) {
    position: absolute;
    z-index: -1;
    right: -28%;
    bottom: 13%;
    width: 90%;
    aspect-ratio: 1;
    border: clamp(0.7rem, 2vw, 1.3rem) solid rgb(var(--color-text-primary) / 0.09);
    border-radius: 50%;
    content: '';
  }

  :global([data-poster='1'] .concert-poster-fallback) { filter: hue-rotate(22deg); }
  :global([data-poster='2'] .concert-poster-fallback) { filter: hue-rotate(46deg); }
  :global([data-poster='3'] .concert-poster-fallback) { filter: hue-rotate(-24deg); }
  :global([data-poster='4'] .concert-poster-fallback) { filter: hue-rotate(82deg); }
  :global([data-poster='5'] .concert-poster-fallback) { filter: hue-rotate(-48deg); }

  :global(.concert-poster-fallback span) {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.62rem;
    letter-spacing: 0.12em;
  }

  :global(.concert-poster-fallback strong) {
    font-family: var(--font-heitang-brand);
    font-size: clamp(1.05rem, 2.2vw, 1.75rem);
    letter-spacing: 0.02em;
    line-height: 1.05;
    overflow-wrap: anywhere;
  }

  :global(.concert-poster-fallback small) {
    color: rgb(var(--color-text-primary) / 0.76);
    font-size: 0.68rem;
    line-height: 1.3;
  }

  .empty-state {
    padding: 6rem 1rem;
    border-top: 1px solid rgb(var(--color-text-primary) / 0.15);
    text-align: center;
  }

  .empty-label {
    color: rgb(var(--color-text-accent));
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    letter-spacing: 0.14em;
  }

  .empty-state p:last-child {
    color: rgb(var(--color-text-secondary));
  }

  @supports (animation-timeline: view()) {
    :global(.concert-card) {
      animation: poster-wall-entry cubic-bezier(0.22, 1, 0.36, 1) both;
      animation-duration: auto;
      animation-range: entry 0% entry 42%;
      animation-timeline: view();
    }
  }

  @keyframes poster-wall-entry {
    from {
      opacity: 0.28;
      transform: perspective(900px) rotateY(-10deg) translateY(2rem);
    }
    to {
      opacity: 1;
      transform: perspective(900px) rotateY(0) translateY(0);
    }
  }

  @media (max-width: 860px) {
    .year-section {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .year-marker {
      position: static;
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      border-bottom: 1px solid rgb(var(--color-text-primary) / 0.15);
    }

    .year-marker h2 {
      font-size: clamp(3.4rem, 16vw, 6rem);
    }
  }

  @media (max-width: 620px) {
    .page-shell {
      width: min(100% - 1.25rem, 1180px);
      padding-top: 5.75rem;
    }

    .page-title {
      font-size: clamp(3rem, 14.6vw, 4.8rem);
    }

    .archive-stats {
      grid-template-columns: repeat(2, 1fr);
    }

    .archive-stats div + div {
      padding-left: 0;
      border-left: 0;
    }

    .archive-stats div:nth-child(even) {
      padding-left: 1.25rem;
      border-left: 1px solid rgb(var(--color-text-primary) / 0.1);
    }

    .archive-stats div:nth-child(n + 3) {
      border-top: 1px solid rgb(var(--color-text-primary) / 0.1);
    }

    .timeline-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 2.5rem 0.75rem;
      padding-left: 1.75rem;
    }

    .timeline-list::before {
      left: 0.32rem;
    }

    :global(.concert-card .timeline-node) {
      display: none;
    }

    :global(.concert-card:nth-child(2n + 1) .timeline-node) {
      left: -1.68rem;
      display: block;
    }

    :global(.concert-poster-fallback strong) {
      font-size: clamp(0.9rem, 4.3vw, 1.2rem);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    :global(.concert-card),
    :global(.timeline-node) {
      animation: none !important;
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }
</style>
