---
import BaseLayout from '../../layouts/BaseLayout.astro';
import InviteCodeCard from '../../components/invite-codes/InviteCodeCard.astro';
import { fetchInviteCodes, extractTags, groupByTag } from '../../services/inviteCodes';
import { useTranslations } from '../../i18n';
import { formatDate } from '../../utils/date';

const lang = 'zh';
const t = useTranslations(lang);

const { codes, updatedAt } = await fetchInviteCodes();
const tags = extractTags(codes);
const groups = groupByTag(codes, tags);
const sectionKeys = Object.keys(groups);
---

<BaseLayout title={t.inviteCodes.title} currentPath="/invite-codes" lang={lang}>
  <div class="container mx-auto px-6 py-24">

    <!-- SVG filter for Liquid Glass refraction (hidden, referenced by CSS backdrop-filter) -->
    <svg style="position:absolute;width:0;height:0;pointer-events:none" aria-hidden="true">
      <defs>
        <filter id="lg-refract" x="-10%" y="-10%" width="120%" height="120%" color-interpolation-filters="sRGB">
          <!-- 低頻噪點 → 模擬玻璃厚度不均勻的折射 -->
          <feTurbulence
            type="fractalNoise"
            baseFrequency="0.018 0.025"
            numOctaves="3"
            seed="42"
            result="noise"
          />
          <!-- 位移背景像素：真實折射扭曲 -->
          <feDisplacementMap
            in="SourceGraphic"
            in2="noise"
            scale="10"
            xChannelSelector="R"
            yChannelSelector="G"
          />
        </filter>
      </defs>
    </svg>

    <!-- Page header -->
    <div class="mb-8">
      <h1 class="font-display text-4xl font-bold mb-3 text-[rgb(var(--color-text-primary))]">
        🎫 {t.inviteCodes.title}
      </h1>
      <p class="text-[rgb(var(--color-text-secondary))] mb-2">
        {t.inviteCodes.description}
      </p>
      <p class="text-xs text-[rgb(var(--color-text-secondary))]">
        {t.inviteCodes.lastUpdated}：{formatDate(updatedAt, lang)}
      </p>
    </div>

    {codes.length === 0 ? (
      <div class="glass p-12 rounded-2xl text-center">
        <p class="text-[rgb(var(--color-text-secondary))] text-lg">{t.inviteCodes.noData}</p>
        <p class="text-[rgb(var(--color-text-secondary))] text-sm mt-3">
          {import.meta.env.INVITE_CODES_API_URL
            ? '無法載入邀請碼，請稍後再試。'
            : '尚未設定 INVITE_CODES_API_URL 環境變數。'}
        </p>
      </div>
    ) : (
      <>
        <!-- Tag filter tabs + toggle -->
        <div class="tag-tabs-wrapper sticky top-16 z-20 mb-8 -mx-2 px-2 py-2">
          <div class="flex items-center gap-3">

            <!-- Scrollable tabs -->
            <div class="relative flex-1 min-w-0">
              <div class="tag-tabs-scroll flex gap-2 overflow-x-auto pb-1 scrollbar-hide">
                <button
                  class="tag-tab active flex-shrink-0 px-4 py-1.5 rounded-full text-sm font-medium
                    transition-all duration-200 whitespace-nowrap"
                  data-tag="__all__"
                >
                  全部
                  <span class="ml-1.5 text-xs opacity-70">({codes.length})</span>
                </button>
                {sectionKeys.map(tag => (
                  <button
                    class="tag-tab flex-shrink-0 px-4 py-1.5 rounded-full text-sm font-medium
                      transition-all duration-200 whitespace-nowrap"
                    data-tag={tag}
                  >
                    {tag}
                    <span class="ml-1.5 text-xs opacity-70">({groups[tag].length})</span>
                  </button>
                ))}
              </div>
              <!-- 右側 fade -->
              <div class="tag-tabs-fade pointer-events-none absolute right-0 top-0 bottom-0 w-12
                bg-gradient-to-l from-[rgb(var(--color-bg-dark))] to-transparent opacity-0
                transition-opacity duration-300" aria-hidden="true"></div>
            </div>

            <!-- Hide expired toggle: filter icon button -->
            <button
              id="hide-expired-toggle"
              class="filter-btn flex-shrink-0 relative w-9 h-9 rounded-xl flex items-center justify-center
                transition-all duration-250
                bg-[rgba(255,255,255,0.06)] border border-[rgba(255,255,255,0.10)]
                text-[rgb(var(--color-text-secondary))]
                hover:bg-[rgba(255,255,255,0.10)] hover:text-[rgb(var(--color-text-primary))]"
              aria-label="篩選有效邀請碼"
              aria-pressed="true"
              title="僅顯示有效邀請碼"
              data-active="true"
            >
              <!-- Filter funnel SVG -->
              <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
                <path d="M1.5 2.5A.5.5 0 0 1 2 2h12a.5.5 0 0 1 .39.812L9.5 8.955V13.5a.5.5 0 0 1-.276.447l-3 1.5A.5.5 0 0 1 5.5 15V8.955L1.61 3.312A.5.5 0 0 1 1.5 2.5z"/>
              </svg>
              <!-- Active indicator dot -->
              <span class="filter-dot absolute top-1 right-1 w-2 h-2 rounded-full
                bg-[rgb(var(--color-primary))] ring-1 ring-[rgb(var(--color-bg-dark))]
                transition-opacity duration-200"></span>
            </button>

          </div>
        </div>

        <!-- Sections -->
        <div class="flex flex-col gap-12">
          {sectionKeys.map(tag => (
            <section class="tag-section" data-section={tag}>
              <h2 class="font-display text-lg font-semibold text-[rgb(var(--color-text-primary))] mb-4 flex items-center gap-2">
                <span class="inline-block w-1 h-5 rounded-full bg-[rgb(var(--color-primary))]"></span>
                {tag}
                <span class="text-xs font-normal text-[rgb(var(--color-text-secondary))] ml-1">
                  ({groups[tag].length})
                </span>
              </h2>
              <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                {groups[tag].map(code => (
                  <InviteCodeCard code={code} />
                ))}
              </div>
            </section>
          ))}
        </div>
      </>
    )}
  </div>

  <!-- ── Invite Code Detail Overlay ── -->
  <div id="ic-overlay" aria-hidden="true">
    <div id="ic-backdrop"></div>

    <!-- Desktop: Modal -->
    <div id="ic-modal" role="dialog" aria-modal="true">
      <button id="ic-close-modal" class="ic-close-btn" aria-label="關閉">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M3 3l10 10M13 3L3 13" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
        </svg>
      </button>
      <div id="ic-detail-modal"></div>
    </div>

    <!-- Mobile: Bottom Sheet -->
    <div id="ic-sheet" role="dialog" aria-modal="true">
      <div id="ic-sheet-drag" aria-hidden="true">
        <div class="ic-handle-bar"></div>
      </div>
      <div id="ic-sheet-scroll">
        <div id="ic-detail-sheet"></div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  /* Tab inactive */
  .tag-tab {
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.10);
    color: rgb(var(--color-text-secondary));
  }
  .tag-tab:hover {
    background: rgba(255, 255, 255, 0.10);
    border-color: rgba(255, 255, 255, 0.18);
    color: rgb(var(--color-text-primary));
  }
  /* Tab active */
  .tag-tab.active {
    background: rgba(var(--color-primary), 0.18);
    border-color: rgba(var(--color-primary), 0.40);
    color: rgb(var(--color-primary));
  }

  /* Sticky tab bar background blur */
  .tag-tabs-wrapper {
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }

  /* Hide scrollbar cross-browser */
  .scrollbar-hide { scrollbar-width: none; }
  .scrollbar-hide::-webkit-scrollbar { display: none; }

  /* Filter button active state */
  .filter-btn[data-active="true"] {
    background: rgba(var(--color-primary), 0.15);
    border-color: rgba(var(--color-primary), 0.35);
    color: rgb(var(--color-primary));
  }
  .filter-btn[data-active="false"] .filter-dot {
    opacity: 0;
  }
  .filter-btn[data-active="false"] {
    color: rgb(var(--color-text-secondary));
    background: rgba(255,255,255,0.06);
    border-color: rgba(255,255,255,0.10);
  }

  /* ── Overlay ── */
  #ic-overlay {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 50;
  }
  #ic-overlay.ic-open { display: block; }

  #ic-backdrop {
    position: absolute;
    inset: 0;
    background: transparent;
    backdrop-filter: blur(0px);
    -webkit-backdrop-filter: blur(0px);
    cursor: pointer;
  }

  /* Modal */
  #ic-modal {
    display: none;
    position: absolute;
    top: 50%;
    left: 50%;
    width: min(520px, calc(100vw - 2rem));
    max-height: min(88vh, 680px);
    overflow-y: auto;
    background: rgb(var(--color-bg-medium));
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 1.5rem;
    padding: 1.75rem;
    box-shadow: 0 32px 80px rgba(0,0,0,0.5);
    scrollbar-width: none;
  }
  #ic-modal::-webkit-scrollbar { display: none; }

  /* Bottom Sheet */
  #ic-sheet {
    display: none;
    position: absolute;
    left: 0; right: 0; bottom: 0;
    max-height: 90vh;
    background: rgb(var(--color-bg-medium));
    border-top: 1px solid rgba(255,255,255,0.1);
    border-radius: 1.5rem 1.5rem 0 0;
    flex-direction: column;
    overflow: hidden;
    will-change: transform;
  }
  #ic-sheet-drag {
    flex-shrink: 0;
    padding: 0.75rem 0 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: grab;
    touch-action: none;
  }
  #ic-sheet-drag:active { cursor: grabbing; }
  .ic-handle-bar {
    width: 2.5rem; height: 4px;
    border-radius: 2px;
    background: rgba(255,255,255,0.2);
  }
  #ic-sheet-scroll {
    flex: 1;
    overflow-y: auto;
    padding: 0.25rem 1.5rem 2.5rem;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }
  #ic-sheet-scroll::-webkit-scrollbar { display: none; }

  /* Close button */
  .ic-close-btn {
    position: absolute;
    top: 1.25rem; right: 1.25rem;
    width: 2rem; height: 2rem;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    color: rgb(var(--color-text-secondary));
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
    z-index: 1;
  }
  .ic-close-btn:hover {
    background: rgba(255,255,255,0.12);
    color: rgb(var(--color-text-primary));
  }

</style>

<style is:global>
  /* ── Invite Code Detail content (dynamically injected via innerHTML) ── */
  .ic-detail-status {
    display: inline-flex; align-items: center; gap: 0.35rem;
    font-size: 0.7rem; font-weight: 600;
    padding: 0.2rem 0.6rem; border-radius: 99px; border: 1px solid;
  }
  .ic-badge-row {
    display: flex; flex-wrap: wrap; align-items: center; gap: 0.4rem;
    margin-top: 0.4rem;
  }
  .ic-detail-title {
    font-size: 1.15rem; font-weight: 700;
    color: rgb(var(--color-text-primary));
    padding-right: 2.5rem;
  }
  .ic-event-link {
    display: inline-flex; align-items: center; gap: 0.3rem;
    font-size: 0.7rem; padding: 0.2rem 0.55rem; border-radius: 99px;
    background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12);
    color: rgb(var(--color-text-secondary)); text-decoration: none; transition: all 0.15s;
  }
  .ic-event-link:hover { background: rgba(255,255,255,0.12); color: rgb(var(--color-text-primary)); }
  .ic-tag {
    display: inline-flex; align-items: center;
    font-size: 0.7rem; padding: 0.2rem 0.6rem; border-radius: 99px;
    background: rgba(var(--color-accent), 0.12);
    color: rgb(var(--color-accent));
    border-width: 1px;
    border-style: solid;
    border-color: rgba(var(--color-accent), 0.2);
  }
  .ic-divider { border: none; border-top: 1px solid rgba(255,255,255,0.08); margin: 1rem 0; }
  .ic-desc { font-size: 0.875rem; color: rgb(var(--color-text-secondary)); line-height: 1.65; word-break: break-word; }
  .ic-desc ul, .ic-desc ol { padding-left: 1.25rem; margin: 0.35rem 0; }
  .ic-desc ul { list-style-type: disc; }
  .ic-desc ol { list-style-type: decimal; }
  .ic-desc li { margin-bottom: 0.2rem; }
  .ic-section-label {
    font-size: 0.68rem; font-weight: 600; letter-spacing: 0.06em;
    text-transform: uppercase; color: rgb(var(--color-text-secondary));
    opacity: 0.6; margin-bottom: 0.4rem;
  }
  .ic-code-row {
    display: flex; align-items: center; gap: 0.5rem;
    background: rgba(0,0,0,0.2);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 0.625rem; padding: 0.625rem 0.75rem;
  }
  .ic-code-value {
    flex: 1; font-family: 'JetBrains Mono', monospace;
    font-size: 0.9rem; color: rgb(var(--color-accent));
    letter-spacing: 0.04em; word-break: break-all;
  }
  .ic-copy-btn {
    flex-shrink: 0; padding: 0.3rem 0.7rem; border-radius: 0.375rem;
    font-size: 0.75rem; font-weight: 500;
    background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);
    color: rgb(var(--color-text-secondary)); cursor: pointer; transition: all 0.15s;
  }
  .ic-copy-btn:hover { background: rgba(255,255,255,0.1); color: rgb(var(--color-text-primary)); }
  .ic-copy-btn.copied { color: #4ade80; border-color: rgba(74,222,128,0.3); }
  .ic-link-btn {
    display: flex; align-items: center; justify-content: center; gap: 0.5rem;
    width: 100%; padding: 0.75rem; border-radius: 0.75rem;
    font-size: 0.9rem; font-weight: 600;
    background: rgb(var(--color-primary));
    border: none;
    color: rgb(var(--color-bg-dark)); text-decoration: none; transition: opacity 0.15s;
    margin-top: 0.25rem;
  }
  .ic-link-btn:hover { opacity: 0.88; }
  .ic-benefits-box {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08); border-radius: 0.75rem; overflow: hidden;
  }
  .ic-benefit-row {
    display: flex; align-items: flex-start; gap: 0.75rem;
    padding: 0.65rem 0.875rem; font-size: 0.825rem;
  }
  .ic-benefit-row + .ic-benefit-row { border-top: 1px solid rgba(255,255,255,0.06); }
  .ic-benefit-icon { font-size: 0.9rem; flex-shrink: 0; margin-top: 0.1rem; }
  .ic-benefit-label { font-size: 0.68rem; color: rgb(var(--color-text-secondary)); opacity: 0.6; margin-bottom: 0.15rem; }
  .ic-benefit-value { color: rgb(var(--color-text-primary)); }
  .ic-date-row {
    display: flex; align-items: center; gap: 0.5rem;
    font-size: 0.78rem; color: rgb(var(--color-text-secondary)); opacity: 0.65;
  }
</style>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.tag-tab');
  const sections = document.querySelectorAll<HTMLElement>('.tag-section');
  const scrollEl = document.querySelector<HTMLElement>('.tag-tabs-scroll');
  const fadeEl = document.querySelector<HTMLElement>('.tag-tabs-fade');
  const filterBtn = document.getElementById('hide-expired-toggle') as HTMLButtonElement;

  let activeTag = '__all__';
  let hideInactive = true;

  function updateFade() {
    if (!scrollEl || !fadeEl) return;
    const hasOverflow = scrollEl.scrollWidth > scrollEl.clientWidth;
    const atEnd = scrollEl.scrollLeft + scrollEl.clientWidth >= scrollEl.scrollWidth - 4;
    fadeEl.style.opacity = (hasOverflow && !atEnd) ? '1' : '0';
  }

  function applyFilter() {
    sections.forEach(section => {
      const sectionTag = section.dataset.section;
      const tagMatch = activeTag === '__all__' || sectionTag === activeTag;

      if (!tagMatch) { section.classList.add('hidden'); return; }

      const cards = section.querySelectorAll<HTMLElement>('[data-status]');
      let visibleCount = 0;
      cards.forEach(card => {
        const status = card.dataset.status;
        const shouldHide = hideInactive && (status === 'expired' || status === 'disabled');
        card.style.display = shouldHide ? 'none' : '';
        if (!shouldHide) visibleCount++;
      });

      section.classList.toggle('hidden', visibleCount === 0);
    });
  }

  scrollEl?.addEventListener('scroll', updateFade);
  window.addEventListener('resize', updateFade);
  updateFade();

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      activeTag = tab.dataset.tag ?? '__all__';
      tabs.forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      applyFilter();
    });
  });

  filterBtn?.addEventListener('click', () => {
    hideInactive = !hideInactive;
    filterBtn.dataset.active = String(hideInactive);
    filterBtn.setAttribute('aria-pressed', String(hideInactive));
    applyFilter();
  });

  applyFilter();

  // ── Invite Code Overlay ────────────────────────────────────────────────────
  const overlay   = document.getElementById('ic-overlay')!;
  const backdrop  = document.getElementById('ic-backdrop')!;
  const modal     = document.getElementById('ic-modal')!;
  const sheet     = document.getElementById('ic-sheet')!;
  const detailM   = document.getElementById('ic-detail-modal')!;
  const detailS   = document.getElementById('ic-detail-sheet')!;
  const sheetScroll = document.getElementById('ic-sheet-scroll')!;
  const sheetDrag   = document.getElementById('ic-sheet-drag')!;

  const SPRING  = 'cubic-bezier(0.34, 1.56, 0.64, 1)';
  const EASE_IO = 'cubic-bezier(0.32, 0.72, 0, 1)';
  const isMobile = () => window.innerWidth < 768;

  // ── Detail HTML renderer ──────────────────────────────────────────────────
  function esc(s: unknown) {
    return String(s ?? '')
      .replace(/&/g, '&amp;').replace(/</g, '&lt;')
      .replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  type InviteData = Record<string, unknown>;

  function renderDetail(c: InviteData): string {
    const statusMap: Record<string, [string, string]> = {
      active:   ['有效',   'color:rgb(74,222,128);border-color:rgba(74,222,128,.3);background:rgba(74,222,128,.1)'],
      expired:  ['已到期', 'color:rgb(248,113,113);border-color:rgba(248,113,113,.3);background:rgba(248,113,113,.1)'],
      disabled: ['已停用', 'color:rgb(161,161,170);border-color:rgba(161,161,170,.3);background:rgba(161,161,170,.1)'],
    };
    const status = String(c.status ?? 'active');
    const [label, style] = statusMap[status] ?? statusMap.active;
    const tags = (Array.isArray(c.tags) ? c.tags : []).map((t: unknown) => `<span class="ic-tag">${esc(t)}</span>`).join('');

    let dateRange = '';
    if (c.start_date && c.end_date) dateRange = `${esc(c.start_date)} → ${esc(c.end_date)}`;
    else if (c.end_date) dateRange = `至 ${esc(c.end_date)}`;

    const hasAction = c.invite_code || c.invite_link;
    const hasBenefit = c.user_benefit || c.my_benefit;

    return `
      <h2 class="ic-detail-title">${esc(c.title)}</h2>
      <div class="ic-badge-row">
        <span class="ic-detail-status" style="${style}">${label}</span>
        ${c.official_link ? `
          <a href="${esc(c.official_link)}" target="_blank" rel="noopener" class="ic-event-link">
            活動頁面
            <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
              <path d="M4 1.5H2A1.5 1.5 0 0 0 .5 3v5A1.5 1.5 0 0 0 2 9.5h5A1.5 1.5 0 0 0 8.5 8V6M6 .5h3.5v3.5M9 1 4.5 5.5"
                stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>` : ''}
      </div>
      ${dateRange ? `
        <div class="ic-date-row" style="margin-top:0.6rem">
          <svg width="13" height="13" viewBox="0 0 13 13" fill="none">
            <rect x="1" y="2.5" width="11" height="9.5" rx="1.5" stroke="currentColor" stroke-width="1.2"/>
            <path d="M4.5 1v3M8.5 1v3M1 6h11" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
          </svg>
          ${dateRange}
        </div>` : ''}
      <hr class="ic-divider" />
      <p class="ic-desc">${formatDesc(String(c.description ?? ''))}</p>
      ${tags ? `<div class="ic-badge-row" style="margin-top:0.75rem">${tags}</div>` : ''}
      ${hasBenefit ? `
        <hr class="ic-divider" />
        <div class="ic-section-label">獲得好處</div>
        <div class="ic-benefits-box">
          ${c.user_benefit ? `<div class="ic-benefit-row"><span class="ic-benefit-icon">🎁</span><div><div class="ic-benefit-label">你獲得</div><div class="ic-benefit-value">${esc(c.user_benefit)}</div></div></div>` : ''}
          ${c.my_benefit ? `<div class="ic-benefit-row"><span class="ic-benefit-icon">🐟</span><div><div class="ic-benefit-label">貓貓獲得</div><div class="ic-benefit-value">${esc(c.my_benefit)}</div></div></div>` : ''}
        </div>` : ''}
      ${hasAction ? '<hr class="ic-divider" />' : ''}
      ${c.invite_code ? `
        <div style="margin-bottom:0.75rem">
          <div class="ic-section-label">邀請碼</div>
          <div class="ic-code-row">
            <span class="ic-code-value">${esc(c.invite_code)}</span>
            <button class="ic-copy-btn" data-copy="${esc(c.invite_code)}">複製</button>
          </div>
        </div>` : ''}
      ${c.invite_link ? `
        <a href="${esc(c.invite_link)}" target="_blank" rel="noopener" class="ic-link-btn">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
            <path d="M6 2H2.5A1.5 1.5 0 0 0 1 3.5v8A1.5 1.5 0 0 0 2.5 13h8A1.5 1.5 0 0 0 12 11.5V8M8 1h5v5M12.5 1.5 6 8"
              stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          前往邀請連結
        </a>` : ''}
    `;
  }

  // ── Description formatter: supports \n, - lists, 1. lists ──────────────
  function formatDesc(raw: string): string {
    const lines = esc(raw).split(/\r?\n/);
    let html = '';
    let inUl = false;
    let inOl = false;

    const closeList = () => {
      if (inUl) { html += '</ul>'; inUl = false; }
      if (inOl) { html += '</ol>'; inOl = false; }
    };

    for (const line of lines) {
      const ul = line.match(/^[-*]\s+(.+)/);
      const ol = line.match(/^\d+\.\s+(.+)/);

      if (ul) {
        if (inOl) { html += '</ol>'; inOl = false; }
        if (!inUl) { html += '<ul>'; inUl = true; }
        html += `<li>${ul[1]}</li>`;
      } else if (ol) {
        if (inUl) { html += '</ul>'; inUl = false; }
        if (!inOl) { html += '<ol>'; inOl = true; }
        html += `<li>${ol[1]}</li>`;
      } else {
        closeList();
        html += line.trim() === '' ? '<br>' : line + '<br>';
      }
    }
    closeList();
    return html.replace(/<br>$/, '');
  }
  function bindCopyBtns(root: HTMLElement) {
    root.querySelectorAll<HTMLButtonElement>('.ic-copy-btn').forEach(btn => {
      btn.addEventListener('click', async e => {
        e.stopPropagation();
        await navigator.clipboard.writeText(btn.dataset.copy ?? '');
        btn.textContent = '✓ 已複製';
        btn.classList.add('copied');
        setTimeout(() => { btn.textContent = '複製'; btn.classList.remove('copied'); }, 1800);
      });
    });
  }

  // ── Open / Close ──────────────────────────────────────────────────────────
  function openOverlay(data: InviteData) {
    overlay.classList.add('ic-open');
    overlay.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';

    requestAnimationFrame(() => {
      backdrop.style.transition = 'background 0.3s, backdrop-filter 0.3s';
      backdrop.style.background = 'rgba(0,0,0,0.65)';
      (backdrop.style as CSSStyleDeclaration & { webkitBackdropFilter: string }).webkitBackdropFilter = 'blur(8px)';
      backdrop.style.backdropFilter = 'blur(8px)';
    });

    if (!isMobile()) {
      detailM.innerHTML = renderDetail(data);
      bindCopyBtns(detailM);
      modal.style.display = 'block';
      modal.style.opacity = '0';
      modal.style.transform = 'translate(-50%, -50%) scale(0.94) translateY(10px)';
      requestAnimationFrame(() => requestAnimationFrame(() => {
        modal.style.transition = `opacity 0.3s ${SPRING}, transform 0.3s ${SPRING}`;
        modal.style.opacity = '1';
        modal.style.transform = 'translate(-50%, -50%) scale(1) translateY(0)';
      }));
    } else {
      detailS.innerHTML = renderDetail(data);
      bindCopyBtns(detailS);
      sheetScroll.scrollTop = 0;
      sheet.style.display = 'flex';
      sheet.style.transform = 'translateY(100%)';
      requestAnimationFrame(() => requestAnimationFrame(() => {
        sheet.style.transition = `transform 0.38s ${EASE_IO}`;
        sheet.style.transform = 'translateY(0)';
      }));
    }
  }

  function closeOverlay() {
    backdrop.style.transition = 'background 0.25s ease-in, backdrop-filter 0.25s ease-in';
    backdrop.style.background = 'rgba(0,0,0,0)';
    backdrop.style.backdropFilter = 'blur(0px)';

    if (!isMobile()) {
      modal.style.transition = 'opacity 0.2s ease-in, transform 0.2s ease-in';
      modal.style.opacity = '0';
      modal.style.transform = 'translate(-50%, -50%) scale(0.94) translateY(10px)';
    } else {
      sheet.style.transition = 'transform 0.3s ease-in';
      sheet.style.transform = 'translateY(100%)';
    }

    setTimeout(() => {
      overlay.classList.remove('ic-open');
      overlay.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      modal.style.cssText = '';
      sheet.style.cssText = '';
      backdrop.style.cssText = '';
    }, 320);
  }

  // ── Card click ───────────────────────────────────────────────────────────
  document.querySelectorAll<HTMLElement>('.ic-card').forEach(card => {
    const activate = () => {
      try { openOverlay(JSON.parse(card.dataset.invite ?? '{}')); } catch {}
    };
    card.addEventListener('click', activate);
    card.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); activate(); }
    });
  });

  backdrop.addEventListener('click', closeOverlay);
  document.getElementById('ic-close-modal')?.addEventListener('click', closeOverlay);
  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Escape' && overlay.classList.contains('ic-open')) closeOverlay();
  });

  // ── Touch drag (Bottom Sheet handle) ─────────────────────────────────────
  let dragStartY = 0, dragCurrentY = 0, isDragging = false;
  let velY = 0, lastTY = 0, lastTT = 0;

  sheetDrag.addEventListener('touchstart', (e: TouchEvent) => {
    const t = e.touches[0];
    dragStartY = dragCurrentY = lastTY = t.clientY;
    lastTT = Date.now(); velY = 0; isDragging = true;
    sheet.style.transition = 'none';
  }, { passive: true });

  window.addEventListener('touchmove', (e: TouchEvent) => {
    if (!isDragging) return;
    const t = e.touches[0];
    dragCurrentY = t.clientY;
    const delta = dragCurrentY - dragStartY;
    const now = Date.now(); const dt = Math.max(now - lastTT, 1);
    velY = (t.clientY - lastTY) / dt;
    lastTY = t.clientY; lastTT = now;

    if (delta > 0) {
      e.preventDefault();
      sheet.style.transform = `translateY(${delta}px)`;
      const progress = Math.min(delta / (sheet.offsetHeight || 600), 1);
      backdrop.style.opacity = String(1 - progress * 0.8);
    }
  }, { passive: false });

  window.addEventListener('touchend', () => {
    if (!isDragging) return;
    isDragging = false;
    const delta = dragCurrentY - dragStartY;
    sheet.style.transition = `transform 0.35s ${EASE_IO}`;
    backdrop.style.transition = 'opacity 0.35s';
    if (delta > 0 && (velY > 0.5 || delta > (sheet.offsetHeight || 600) * 0.4)) {
      closeOverlay();
    } else {
      sheet.style.transform = 'translateY(0)';
      backdrop.style.opacity = '1';
    }
  }, { passive: true });
</script>

