---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations, localePath } from '../i18n';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BaseLayout title={`404 — ${t.error.notFound}`} lang={lang}>
  <div class="flex flex-col items-center justify-center min-h-[80vh] px-6 text-center">
    <div class="bento-cell p-12 max-w-lg w-full">
      <div class="text-8xl mb-6 animate-bounce">🐱</div>
      <h1 class="font-display text-6xl font-bold text-[rgb(var(--color-primary))] mb-4">404</h1>
      <p class="text-xl font-semibold text-[rgb(var(--color-text-primary))] mb-3">
        {t.error.notFound}
      </p>
      <p class="text-[rgb(var(--color-text-secondary))] mb-8 leading-relaxed">
        {t.error.desc}
      </p>
      <a
        href={localePath('/', lang)}
        class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-medium
          bg-[rgba(var(--color-primary),0.15)] text-[rgb(var(--color-primary))]
          border border-[rgba(var(--color-primary),0.3)]
          hover:bg-[rgba(var(--color-primary),0.25)] hover:border-[rgba(var(--color-primary),0.5)]
          transition-all duration-200"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
        </svg>
        {t.error.goHome}
      </a>
    </div>
  </div>
</BaseLayout>
