---
/**
 * BlogLayout — Layout for individual blog posts
 * Liskov Substitution: interchangeable with BaseLayout via consistent props
 */
import BaseLayout from './BaseLayout.astro';
import { siteConfig } from '../config/site';
import { formatDate } from '../utils/date';
import type { PostMeta } from '../types/blog';

export interface Props {
  post: PostMeta;
  slug: string;
  readingTime: number;
  lang?: 'zh' | 'en';
}

const { post, slug, readingTime, lang = 'zh' } = Astro.props;

const title = lang === 'en' && post.titleEn ? post.titleEn : post.title;
const description = lang === 'en' && post.descriptionEn ? post.descriptionEn : post.description;
const postUrl = `${siteConfig.url}${lang === 'en' ? '/en' : ''}/blog/${slug}`;
---

<BaseLayout title={title} description={description} lang={lang} currentPath="/blog">
  <!-- OG meta for article -->
  <Fragment slot="head">
    <meta property="og:type" content="article" />
    <meta property="og:url" content={postUrl} />
    {post.cover && <meta property="og:image" content={post.cover} />}
    <meta property="article:published_time" content={post.pubDate.toISOString()} />
    {post.updatedDate && <meta property="article:modified_time" content={post.updatedDate.toISOString()} />}
  </Fragment>

  <div class="container mx-auto px-6 py-24 max-w-3xl">
    <!-- Back link -->
    <a
      href={lang === 'en' ? '/en/blog' : '/blog'}
      class="inline-flex items-center gap-2 text-sm text-[rgb(var(--color-text-secondary))] hover:text-[rgb(var(--color-primary))] transition-colors mb-8"
    >
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      {lang === 'zh' ? '返回文章列表' : 'Back to Blog'}
    </a>

    <!-- Article header -->
    <header class="mb-10">
      <!-- Tags -->
      {post.tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-4">
          {post.tags.map(tag => (
            <span class="tag-badge">{tag}</span>
          ))}
        </div>
      )}

      <h1 class="font-display text-3xl md:text-4xl font-bold leading-tight mb-4 text-[rgb(var(--color-text-primary))]">
        {title}
      </h1>

      <p class="text-[rgb(var(--color-text-secondary))] text-lg mb-6">{description}</p>

      <!-- Meta bar -->
      <div class="flex flex-wrap items-center gap-4 text-sm text-[rgb(var(--color-text-secondary))] pb-6 border-b border-[var(--glass-border)]">
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          {formatDate(post.pubDate, lang)}
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          {readingTime} {lang === 'zh' ? '分鐘閱讀' : 'min read'}
        </span>
        <span>{post.author}</span>
      </div>
    </header>

    <!-- Article body -->
    <article
      class="prose prose-invert prose-lg max-w-none
        prose-headings:font-display prose-headings:text-[rgb(var(--color-text-primary))] prose-headings:font-bold
        prose-h1:text-3xl prose-h2:text-2xl prose-h3:text-xl
        prose-p:text-[rgb(var(--color-text-secondary))] prose-p:leading-relaxed
        prose-a:text-[rgb(var(--color-primary))] prose-a:no-underline hover:prose-a:underline prose-a:font-medium
        prose-strong:text-[rgb(var(--color-text-primary))] prose-strong:font-semibold
        prose-em:text-[rgb(var(--color-text-secondary))]
        prose-li:text-[rgb(var(--color-text-secondary))] prose-li:leading-relaxed
        prose-ul:my-4 prose-ol:my-4
        prose-code:text-[rgb(var(--color-accent))] prose-code:bg-white/[0.07] prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:text-sm prose-code:font-mono prose-code:before:content-none prose-code:after:content-none
        prose-pre:bg-white/[0.05] prose-pre:border prose-pre:border-white/10 prose-pre:rounded-xl prose-pre:backdrop-blur-md prose-pre:my-6
        prose-blockquote:border-l-4 prose-blockquote:border-[rgb(var(--color-primary))] prose-blockquote:bg-white/[0.03] prose-blockquote:rounded-r-lg prose-blockquote:px-6 prose-blockquote:py-4 prose-blockquote:text-[rgb(var(--color-text-secondary))] prose-blockquote:not-italic
        prose-hr:border-white/10
        prose-img:rounded-xl prose-img:border prose-img:border-white/10
        prose-table:text-[rgb(var(--color-text-secondary))]
        prose-th:text-[rgb(var(--color-text-primary))] prose-th:border-white/10
        prose-td:border-white/10"
      data-pagefind-body
    >
      <slot />
    </article>
  </div>
</BaseLayout>
